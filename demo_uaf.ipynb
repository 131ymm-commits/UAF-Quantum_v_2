2. Генерация эталонных данных (осцилляции Раби)
Используем стандартную модель Линдблада с частотой Раби Ω=1.5 и временем жизни T1=50 мкс.

python
from scipy.integrate import solve_ivp

def lindblad_rabi(t, y, Omega, gamma):
    rho00, rho11, rho_re, rho_im = y
    w = rho11 - rho00
    u = 2*rho_re; v = 2*rho_im
    du = -gamma * u
    dv = -Omega * w - gamma * v
    dw = Omega * v - gamma * (w + 1)
    return [-dw/2, dw/2, du/2, dv/2]

t_data = np.linspace(0, 150, 300)
gamma = 1/50.0
Omega_rabi = 1.5
sol = solve_ivp(lindblad_rabi, (0, 150), [0,1,0,0], args=(Omega_rabi, gamma),
                t_eval=t_data, method='LSODA')
P_truth = sol.y[1]
3. Подгонка UAF под эти данные
python
model = UAFModel()
opt_params, mse = model.fit(t_data, P_truth)
print(f"MSE = {mse:.6f}")
print(f"Параметры: hbar={opt_params[0]:.3f}, Omega={opt_params[1]:.3f}, Delta={opt_params[2]:.3f}, lam={opt_params[3]:.5f}, eta={opt_params[4]:.5f}, xi={opt_params[5]:.3f}")
4. Сравнение графиков
python
t_uaf, P_uaf = model.run((0, 150), t_data)

plt.figure(figsize=(8,5))
plt.plot(t_data, P_truth, 'b-', label='Линдблад (эталон)')
plt.plot(t_uaf, P_uaf, 'r--', label='UAF (подогнанная)')
plt.xlabel('Время (мкс)')
plt.ylabel('Населенность верхнего уровня')
plt.title('Сравнение UAF с эталонной когерентной динамикой')
plt.legend()
plt.grid()
plt.show()
