"""
UAF-Quantum Model (Unitary And Fault-tolerant)
Реализация модели тройственности времени: прошлое (α), настоящее (Γ), будущее (β).

Уравнения основаны на комплексном будущем и резонансной подкачке.
Параметры имеют физический смысл:
- hbar : квант действия (масштаб времени)
- Omega : частота Раби
- Delta : детьюнинг
- lam  : скорость кристаллизации настоящего в прошлое
- eta  : скорость расходования будущего
- xi   : связь настоящего с мнимой частью будущего (отвечает за осцилляции)

Модель хорошо описывает затухающие когерентные осцилляции (например, осцилляции Раби),
но не подходит для чисто экспоненциальной релаксации.
"""

import numpy as np
from scipy.integrate import solve_ivp
from scipy.optimize import minimize
from dataclasses import dataclass
from typing import Optional, Tuple, Callable

@dataclass
class UAFParams:
    hbar: float = 2.0
    Omega: float = 1.2
    Delta: float = 0.4
    lam: float = 0.08
    eta: float = 0.08
    xi: float = 0.2

class UAFModel:
    """Модель UAF для симуляции и подгонки."""
    
    def __init__(self, params: Optional[UAFParams] = None):
        self.params = params or UAFParams()
        self._y0 = [0.9, 0.05, 0.05, 0.0, 0.0]  # Gamma, alpha, beta_re, beta_im, phi
    
    def set_initial(self, Gamma0: float = 0.9, alpha0: float = 0.05,
                    beta_re0: float = 0.05, beta_im0: float = 0.0, phi0: float = 0.0):
        self._y0 = [Gamma0, alpha0, beta_re0, beta_im0, phi0]
    
    def _rhs(self, t, y):
        p = self.params
        Gamma, alpha, beta_re, beta_im, phi = y
        beta_mag = np.hypot(beta_re, beta_im)
        dGamma = (p.eta * beta_mag * (1 - Gamma) - p.lam * alpha * Gamma +
                  p.xi * (-beta_im) * (1 - Gamma) * beta_mag) / p.hbar
        dalpha = (p.lam * Gamma * (1 - alpha)) / p.hbar
        dbeta_re = -p.eta * beta_im * Gamma / p.hbar
        dbeta_im =  p.eta * beta_re * Gamma / p.hbar
        dphi = p.Delta + p.Omega * Gamma
        return [dGamma, dalpha, dbeta_re, dbeta_im, dphi]
    
    def run(self, t_span: Tuple[float, float], t_eval: Optional[np.ndarray] = None):
        """Запускает симуляцию и возвращает время, населённость верхнего уровня."""
        if t_eval is None:
            t_eval = np.linspace(t_span[0], t_span[1], 1000)
        sol = solve_ivp(self._rhs, t_span, self._y0, t_eval=t_eval,
                        method='LSODA', rtol=1e-8, atol=1e-10)
        Gamma = sol.y[0]
        phi = sol.y[4]
        P_upper = 0.5 * (1 + Gamma * np.cos(phi))
        return sol.t, P_upper
    
    def fit(self, t_data: np.ndarray, P_data: np.ndarray,
            initial_params: Optional[list] = None,
            method: str = 'Nelder-Mead', maxiter: int = 500) -> Tuple[np.ndarray, float]:
        """
        Подгоняет параметры модели под экспериментальные данные (t, P_upper).
        Возвращает (opt_params, MSE).
        """
        if initial_params is None:
            initial_params = [self.params.hbar, self.params.Omega, self.params.Delta,
                              self.params.lam, self.params.eta, self.params.xi]
        
        def loss(params):
            p = UAFParams(hbar=params[0], Omega=params[1], Delta=params[2],
                          lam=params[3], eta=params[4], xi=params[5])
            self.params = p
            try:
                _, P_model = self.run((0, max(t_data)), t_data)
                return np.mean((P_model - P_data) ** 2)
            except:
                return 1e10
        
        res = minimize(loss, initial_params, method=method,
                       options={'maxiter': maxiter, 'xatol': 1e-6})
        self.params = UAFParams(hbar=res.x[0], Omega=res.x[1], Delta=res.x[2],
                                lam=res.x[3], eta=res.x[4], xi=res.x[5])
        return res.x, res.fun

# Пример использования
if __name__ == "__main__":
    import matplotlib.pyplot as plt
    
    # Генерация тестовых данных (осцилляции Раби через Линдблада)
    from scipy.integrate import solve_ivp
    def lindblad_rabi(t, y, Omega, gamma):
        rho00, rho11, rho_re, rho_im = y
        w = rho11 - rho00
        u = 2*rho_re; v = 2*rho_im
        du = -gamma * u
        dv = -Omega * w - gamma * v
        dw = Omega * v - gamma * (w + 1)
        return [-dw/2, dw/2, du/2, dv/2]
    
    t_test = np.linspace(0, 150, 300)
    gamma = 1/50.0
    Omega_rabi = 1.5
    sol = solve_ivp(lindblad_rabi, (0, 150), [0,1,0,0], args=(Omega_rabi, gamma),
                    t_eval=t_test, method='LSODA')
    P_truth = sol.y[1]
    
    # Подгонка UAF
    model = UAFModel()
    opt_params, mse = model.fit(t_test, P_truth)
    t_uaf, P_uaf = model.run((0, 150), t_test)
    
    print(f"Подогнанные параметры: hbar={opt_params[0]:.3f}, Omega={opt_params[1]:.3f}, "
          f"Delta={opt_params[2]:.3f}, lam={opt_params[3]:.5f}, eta={opt_params[4]:.5f}, xi={opt_params[5]:.3f}")
    print(f"MSE = {mse:.6f}")
    
    plt.plot(t_test, P_truth, 'b-', label='Линдблад (осцилляции)')
    plt.plot(t_uaf, P_uaf, 'r--', label='UAF (подогнанная)')
    plt.legend(); plt.grid(); plt.show()# Демонстрация модели UAF-Quantum

